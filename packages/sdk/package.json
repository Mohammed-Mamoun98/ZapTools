{
  "name": "@zap-tools/sdk",
  "version": "0.0.2",
  "description": "ZapTools SDK \u2014 createZapServer (server) and useZapChat hook (client via /client subpath)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./client": {
      "import": "./dist/client-entry.js",
      "types": "./dist/client-entry.d.ts"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "sideEffects": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mohammed-Mamoun98/ZapTools.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/Mohammed-Mamoun98/ZapTools#readme",
  "bugs": {
    "url": "https://github.com/Mohammed-Mamoun98/ZapTools/issues"
  },
  "keywords": [
    "ai",
    "chat",
    "openrouter",
    "vercel-ai-sdk",
    "streaming",
    "tool-calling",
    "zap-tools",
    "react-hook",
    "client-hook"
  ],
  "author": "Mohammed Alshaer",
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf dist",
    "lint": "biome check src",
    "format": "biome format --write src"
  },
  "dependencies": {
    "ai": "^4.1.0",
    "zod": "^3.24.0",
    "@openrouter/ai-sdk-provider": "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsdown": "^0.12.0",
    "typescript": "^5.7.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
